---
import { CONTACT } from '../config';
const year = new Date().getFullYear();
---

<footer class="mt-32 md:mt-48 border-t border-hairline">
  <div class="max-w-[80rem] mx-auto px-6 md:px-10 lg:px-16 py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-7">
        <p class="display-3">Let's build something.</p>
        <p class="mt-4 text-muted max-w-[34rem]">
          Open to conversations on AI-native hardware, founding-team roles, and product-led research.
        </p>
      </div>
      <div class="md:col-span-5 flex flex-col gap-3 md:items-end">
        <a href={`mailto:${CONTACT.email}`} class="underline-accent text-[15px]">
          {CONTACT.email}
        </a>
        <a href={CONTACT.linkedin} target="_blank" rel="noopener" class="underline-accent text-[15px]">
          LinkedIn
        </a>
        <a href={CONTACT.twitter} target="_blank" rel="noopener" class="underline-accent text-[15px]">
          X / Twitter
        </a>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-hairline flex flex-col md:flex-row md:items-center md:justify-between gap-2 text-[13px] text-faint">
      <div>© {year} Kush Dasadia · Fable Engineering</div>
      <div>San Francisco</div>
    </div>
  </div>
</footer>
