---
import { Image } from 'astro:assets';

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  size?: 'wide' | 'full';
}

const { src, alt, caption, size = 'wide' } = Astro.props;

const wrapperClass =
  size === 'full'
    ? 'my-12 md:my-20 -mx-6 md:mx-0'
    : 'my-12 md:my-20';
---

<figure class={wrapperClass}>
  <div class="bg-[#EFEEEC] overflow-hidden">
    <Image
      src={src}
      alt={alt}
      widths={[640, 960, 1280, 1600, 2000]}
      sizes="(min-width: 1024px) 60vw, 100vw"
      quality={88}
      class="w-full h-auto"
    />
  </div>
  {caption && (
    <figcaption class="mt-3 text-[13px] text-muted">
      {caption}
    </figcaption>
  )}
</figure>
