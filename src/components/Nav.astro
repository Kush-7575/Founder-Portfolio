---
import { CONTACT } from '../config';
const { pathname } = Astro.url;
const onHome = pathname === '/' || pathname === '';
---

<nav class="sticky top-0 z-50 backdrop-blur-md bg-[color-mix(in_oklab,var(--color-bg)_82%,transparent)] border-b border-hairline/0">
  <div class="max-w-[80rem] mx-auto px-6 md:px-10 lg:px-16 h-16 flex items-center justify-between">
    <a href="/" class="text-[15px] font-medium tracking-tight">
      Kush Dasadia
    </a>

    <div class="flex items-center gap-6 md:gap-8">
      {onHome ? (
        <a href="#work" class="text-[14px] text-muted hover:text-ink transition-colors">Work</a>
      ) : (
        <a href="/#work" class="text-[14px] text-muted hover:text-ink transition-colors">Work</a>
      )}
      <a href={`mailto:${CONTACT.email}`} class="text-[14px] text-muted hover:text-ink transition-colors hidden sm:inline">Contact</a>
    </div>
  </div>
</nav>
