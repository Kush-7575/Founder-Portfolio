---
import BaseLayout from './BaseLayout.astro';
import ProjectMeta from '../components/ProjectMeta.astro';
import VideoPlaceholder from '../components/VideoPlaceholder.astro';
import ImageFigure from '../components/ImageFigure.astro';
import { Image } from 'astro:assets';

interface Props {
  title: string;
  tagline: string;
  status?: string;
  role: string[];
  scale?: string;
  liveUrl?: string;
  hero?: ImageMetadata;
  heroPlaceholder?: boolean;
  video?: string;
  videoPlaceholder?: string;
  prev?: { slug: string; title: string } | null;
  next?: { slug: string; title: string } | null;
}

const {
  title,
  tagline,
  status,
  role,
  scale,
  liveUrl,
  hero,
  heroPlaceholder,
  video,
  videoPlaceholder,
  prev,
  next,
} = Astro.props;

const rawVideoSrc = video?.startsWith('/') ? video : video ? `/videos/${video}` : undefined;
// Media-fragment hint so the browser renders a real first frame as the poster.
const videoSrc = rawVideoSrc ? `${rawVideoSrc}#t=0.5` : undefined;
---

<BaseLayout title={title} description={tagline}>
  <article class="pt-12 md:pt-20">
    <div class="max-w-[80rem] mx-auto px-6 md:px-10 lg:px-16">
      <a href="/#work" class="text-[14px] text-muted hover:text-ink transition-colors inline-flex items-center gap-1.5">
        <span aria-hidden="true">←</span> Selected Work
      </a>

      <header class="mt-10 md:mt-16 grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-start">
        <div class="md:col-span-7">
          <p class="eyebrow">{tagline}</p>
          <h1 class="display-1 mt-4">{title}</h1>
        </div>
        <div class="md:col-span-5 md:pt-3">
          <ProjectMeta
            status={status}
            role={role}
            scale={scale}
            liveUrl={liveUrl}
          />
        </div>
      </header>

      {hero && (
        <div class="mt-14 md:mt-24 bg-[#EFEEEC] overflow-hidden">
          <Image
            src={hero}
            alt={`${title} hero`}
            widths={[800, 1200, 1600, 2000, 2400]}
            sizes="(min-width: 1280px) 1280px, 100vw"
            quality={92}
            class="w-full h-auto"
          />
        </div>
      )}

      {!hero && heroPlaceholder && !videoSrc && (
        <div class="mt-14 md:mt-24 aspect-[16/9] bg-[#F2F1EE] border border-hairline flex flex-col items-start justify-end p-10 md:p-16">
          <p class="eyebrow">Visuals coming</p>
          <p class="display-2 mt-4 max-w-[24ch]">{title}</p>
        </div>
      )}

      {videoSrc && (
        <figure class="mt-14 md:mt-24">
          <div class="bg-black overflow-hidden flex justify-center">
            <video
              src={videoSrc}
              controls
              playsinline
              preload="metadata"
              class="block max-h-[62vh] w-auto h-auto"
            ></video>
          </div>
        </figure>
      )}

      {!videoSrc && videoPlaceholder && (
        <VideoPlaceholder filename={videoPlaceholder} caption={`${title} product walkthrough`} />
      )}

      <div class="mt-14 md:mt-24 grid grid-cols-1 md:grid-cols-12 gap-8">
        <div class="md:col-span-8 md:col-start-3">
          <div class="prose-body">
            <slot />
          </div>
        </div>
      </div>
    </div>

    <nav class="mt-32 md:mt-48 border-t border-hairline">
      <div class="max-w-[80rem] mx-auto px-6 md:px-10 lg:px-16 py-12 grid grid-cols-2 gap-8">
        <div>
          {prev && (
            <a href={`/work/${prev.slug}`} class="group block">
              <p class="eyebrow">Previous</p>
              <p class="display-3 mt-2 group-hover:text-accent transition-colors">{prev.title}</p>
            </a>
          )}
        </div>
        <div class="text-right">
          {next && (
            <a href={`/work/${next.slug}`} class="group block">
              <p class="eyebrow">Next</p>
              <p class="display-3 mt-2 group-hover:text-accent transition-colors">{next.title}</p>
            </a>
          )}
        </div>
      </div>
    </nav>
  </article>
</BaseLayout>
