---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WorkCard from '../components/WorkCard.astro';

const work = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout>
  <Hero />

  <section id="work" class="border-t border-hairline">
    <div class="max-w-[80rem] mx-auto px-6 md:px-10 lg:px-16 py-20 md:py-32">
      <div class="mb-16 md:mb-24">
        <p class="eyebrow mb-4">Selected Work</p>
        <h2 class="display-2 max-w-[24ch]">Founder journey portfolio.</h2>
      </div>

      <div class="flex flex-col gap-24 md:gap-40">
        {work.map((entry, idx) => (
          <WorkCard
            href={`/work/${entry.id}`}
            title={entry.data.title}
            tagline={entry.data.tagline}
            status={entry.data.status}
            hero={entry.data.hero}
            heroPlaceholder={entry.data.heroPlaceholder}
            liveUrl={entry.data.liveUrl}
            index={idx + 1}
          />
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
